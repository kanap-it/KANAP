---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section, PageHeader, Callout } from '../sections';
import { getLocaleFromUrl, localePath } from '../../i18n/ui';
import { getTrialContent } from '../../content/resolve';

const locale = getLocaleFromUrl(Astro.url);
const c = getTrialContent(locale).checkEmail;
---

<BaseLayout title={c.title} description={c.description}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <PageHeader eyebrow={c.eyebrow} title={c.heading} lead={c.lead} />

  <Section tone="default">
    <div class="mk-check">
      <div class="mk-check__icon" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="6" y="12" width="36" height="24" rx="4" />
          <path d="M6 16l18 12 18-12" />
        </svg>
      </div>

      <section class="mk-check__next">
        <h3>{c.whatNext}</h3>
        <ol>
          {c.steps.map((s) => <li>{s}</li>)}
        </ol>
      </section>

      <Callout>
        <p><strong>{c.noEmailTitle}</strong></p>
        <p>{c.noEmailBody}</p>
        <p>
          <a href={localePath(locale, '/trial/start')}>{c.restartLabel} →</a>
        </p>
      </Callout>
    </div>
  </Section>
</BaseLayout>

<style>
  .mk-check {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-width: 640px;
  }

  .mk-check__icon {
    color: var(--kanap-teal);
  }

  .mk-check__next h3 {
    font-size: 14px;
    font-weight: 500;
    color: var(--kanap-text-tertiary);
    letter-spacing: 0.04em;
    margin: 0 0 14px;
  }

  .mk-check__next ol {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: step;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .mk-check__next li {
    counter-increment: step;
    position: relative;
    padding-left: 40px;
    min-height: 28px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--kanap-text-secondary);
  }

  .mk-check__next li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    color: var(--kanap-teal);
    background: var(--kanap-nav-chip-bg);
    border: 1px solid var(--kanap-nav-chip-border);
    border-radius: var(--kanap-radius-avatar);
  }
</style>
