---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  Section,
  PageHeader,
  PillarGrid,
  CTABand,
  Callout,
} from './sections';
import { getLocaleFromUrl, localePath } from '../i18n/ui';
import { getOnPremContent } from '../content/resolve';

const locale = getLocaleFromUrl(Astro.url);
const content = getOnPremContent(locale);

function resolveHref(href: string): string {
  if (href.startsWith('http')) return href;
  return localePath(locale, href);
}
---

<BaseLayout title={content.meta.title} description={content.meta.description}>
  <PageHeader eyebrow={content.header.eyebrow} title={content.header.title} lead={content.header.lead}>
    <Fragment slot="meta">
      <div class="mk-onprem-head__cta">
        <a href={content.header.primaryHref} rel="noopener" target="_blank" class="mk-btn mk-btn--primary">
          {content.header.primaryCta}
        </a>
        <a href={content.header.secondaryHref} rel="noopener" target="_blank" class="mk-btn mk-btn--ghost">
          {content.header.secondaryCta}
        </a>
      </div>
    </Fragment>
  </PageHeader>

  {/* Why self-host */}
  <Section tone="default">
    <PillarGrid
      eyebrow={content.why.eyebrow}
      title={content.why.title}
      intro={content.why.intro}
      pillars={content.why.pillars}
    />
  </Section>

  {/* License callout */}
  <Section tone="sunken">
    <div class="mk-license">
      <h2 class="mk-license__title">{content.license.title}</h2>
      <p class="mk-lead mk-license__body">{content.license.body}</p>
      <ul class="mk-license__bullets">
        {content.license.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <a href={content.license.linkHref} rel="noopener" target="_blank" class="mk-license__link">
        {content.license.linkLabel} →
      </a>
    </div>
  </Section>

  {/* Deploy */}
  <Section tone="default">
    <header class="mk-deploy-head">
      <span class="mk-eyebrow">{content.deploy.eyebrow}</span>
      <h2 class="mk-deploy-head__title">{content.deploy.title}</h2>
      <p class="mk-lead mk-deploy-head__intro">{content.deploy.intro}</p>
    </header>
    <ol class="mk-deploy-steps">
      {content.deploy.steps.map((step, i) => (
        <li class="mk-deploy-step">
          <span class="mk-deploy-step__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="mk-deploy-step__body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
            {step.code && <pre class="mk-deploy-step__code"><code>{step.code}</code></pre>}
          </div>
        </li>
      ))}
    </ol>
    <div class="mk-deploy-cta">
      <a href={content.deploy.docsHref} rel="noopener" target="_blank" class="mk-btn mk-btn--primary">
        {content.deploy.docsCtaLabel} →
      </a>
    </div>

    <aside class="mk-deploy-manual">
      <span class="mk-eyebrow">{content.deploy.manualOption.label}</span>
      <h3 class="mk-deploy-manual__title">{content.deploy.manualOption.title}</h3>
      <p class="mk-deploy-manual__body">{content.deploy.manualOption.body}</p>
      <a
        href={content.deploy.manualOption.ctaHref}
        rel="noopener"
        target="_blank"
        class="mk-btn mk-btn--ghost mk-deploy-manual__cta"
      >
        {content.deploy.manualOption.ctaLabel} →
      </a>
    </aside>
  </Section>

  {/* Requirements */}
  <Section tone="sunken">
    <div class="mk-req">
      <h2 class="mk-req__title">{content.requirements.title}</h2>
      <p class="mk-lead mk-req__intro">{content.requirements.intro}</p>
      <dl class="mk-req__list">
        {content.requirements.items.map((item) => (
          <div class="mk-req__row">
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </Section>

  {/* Operations */}
  <Section tone="default">
    <PillarGrid
      title={content.operations.title}
      intro={content.operations.intro}
      pillars={content.operations.items}
    />
  </Section>

  {/* Support hint */}
  <Section tone="sunken" compact>
    <Callout>
      <p><strong>{content.support.title}</strong></p>
      <p>{content.support.body}</p>
      <ul>
        {content.support.bullets.map((b) => <li>{b}</li>)}
      </ul>
      <p><a href={resolveHref(content.support.ctaHref)}>{content.support.ctaLabel} →</a></p>
    </Callout>
  </Section>

  {/* CTA */}
  <Section tone="default" compact>
    <CTABand
      title={content.cta.title}
      body={content.cta.body}
      primaryHref="https://github.com/kanap-it/kanap"
      primaryLabel={content.cta.primary}
      secondaryHref={localePath(locale, '/contact')}
      secondaryLabel={content.cta.secondary}
    />
  </Section>
</BaseLayout>

<style>
  .mk-onprem-head__cta {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  /* License */
  .mk-license {
    max-width: 720px;
  }
  .mk-license__title {
    margin: 0 0 12px;
  }
  .mk-license__body {
    margin: 0 0 20px;
  }
  .mk-license__bullets {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mk-license__bullets li {
    position: relative;
    padding-left: 22px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--kanap-text-secondary);
  }
  .mk-license__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 12px;
    height: 1px;
    background: var(--kanap-text-tertiary);
  }
  .mk-license__link {
    color: var(--kanap-teal);
    font-size: 14px;
    font-weight: 500;
  }

  /* Deploy */
  .mk-deploy-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 40px;
  }
  .mk-deploy-head__title {
    margin: 0;
  }
  .mk-deploy-head__intro {
    max-width: 640px;
  }

  .mk-deploy-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 820px;
  }

  .mk-deploy-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    padding: 24px;
    background: var(--kanap-bg-primary);
    border: 1px solid var(--kanap-border-default);
    border-radius: var(--kanap-radius-composer);
  }

  .mk-deploy-step__num {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 22px;
    font-weight: 500;
    color: var(--kanap-text-tertiary);
    line-height: 1;
  }

  .mk-deploy-step__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mk-deploy-step__body h3 {
    font-size: 16px;
    font-weight: 500;
    margin: 0;
  }

  .mk-deploy-step__body p {
    font-size: 14px;
    line-height: 1.55;
    color: var(--kanap-text-secondary);
    margin: 0;
  }

  .mk-deploy-step__code {
    margin: 6px 0 0;
    padding: 14px 16px;
    background: var(--kanap-bg-page);
    border: 1px solid var(--kanap-border-soft);
    border-radius: var(--kanap-radius-submit);
    overflow-x: auto;
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--kanap-text-primary);
  }

  .mk-deploy-cta {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* "Or install manually" — secondary path, presented as a sibling block */
  .mk-deploy-manual {
    margin-top: 36px;
    padding: 24px;
    max-width: 820px;
    background: var(--kanap-bg-drawer);
    border: 1px solid var(--kanap-border-default);
    border-radius: var(--kanap-radius-composer);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .mk-deploy-manual__title {
    font-size: 18px;
    font-weight: 500;
    color: var(--kanap-text-primary);
    margin: 0;
    line-height: 1.3;
    /* Don't pre-line-break this title */
    white-space: normal;
    text-wrap: initial;
  }

  .mk-deploy-manual__body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--kanap-text-secondary);
    margin: 0;
  }

  .mk-deploy-manual__cta {
    margin-top: 6px;
    align-self: flex-start;
  }

  /* Requirements */
  .mk-req {
    max-width: 760px;
  }
  .mk-req__title {
    margin: 0 0 12px;
  }
  .mk-req__intro {
    margin-bottom: 24px;
  }
  .mk-req__list {
    margin: 0;
    padding: 0;
    background: var(--kanap-bg-primary);
    border: 1px solid var(--kanap-border-default);
    border-radius: var(--kanap-radius-composer);
  }
  .mk-req__row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 16px;
    padding: 14px 20px;
    font-size: 14px;
    align-items: baseline;
  }
  .mk-req__row + .mk-req__row {
    border-top: 1px solid var(--kanap-border-soft);
  }
  .mk-req__row dt {
    font-size: 12px;
    color: var(--kanap-text-tertiary);
    font-weight: 500;
    margin: 0;
  }
  .mk-req__row dd {
    margin: 0;
    color: var(--kanap-text-secondary);
    line-height: 1.5;
  }
  @media (max-width: 620px) {
    .mk-req__row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>
