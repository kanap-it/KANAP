---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section, PageHeader, Callout } from './sections';
import { getLocaleFromUrl } from '../i18n/ui';
import { getChangelogContent } from '../content/resolve';

const locale = getLocaleFromUrl(Astro.url);
const c = getChangelogContent(locale);

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString(locale, { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title={c.meta.title} description={c.meta.description}>
  <PageHeader eyebrow={c.header.eyebrow} title={c.header.title} lead={c.header.lead} />

  <Section tone="default">
    <div class="mk-changelog">
      <Callout>
        <p><strong>{c.subscribe.label}</strong> — {c.subscribe.body} <a href={c.subscribe.githubHref} rel="noopener" target="_blank">{c.subscribe.githubCta} →</a></p>
      </Callout>

      <ol class="mk-changelog__list">
        {c.entries.map((entry) => (
          <li class="mk-changelog__entry">
            <div class="mk-changelog__meta">
              <time datetime={entry.date} class="mk-changelog__date">{formatDate(entry.date)}</time>
              {entry.version && <span class="mk-changelog__version">{entry.version}</span>}
            </div>
            <div class="mk-changelog__body">
              <h2>{entry.title}</h2>
              <p>{entry.summary}</p>
              {entry.sections && entry.sections.map((sec) => (
                <div class="mk-changelog__section">
                  <h3>{sec.label}</h3>
                  <ul>
                    {sec.items.map((i) => <li>{i}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </Section>
</BaseLayout>

<style>
  .mk-changelog {
    display: flex;
    flex-direction: column;
    gap: 40px;
    max-width: 820px;
  }

  .mk-changelog__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .mk-changelog__entry {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 28px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--kanap-border-soft);
  }

  .mk-changelog__entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  @media (max-width: 680px) {
    .mk-changelog__entry {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .mk-changelog__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mk-changelog__date {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--kanap-text-tertiary);
    letter-spacing: 0.02em;
  }

  .mk-changelog__version {
    font-size: 11px;
    color: var(--kanap-text-secondary);
  }

  .mk-changelog__body {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .mk-changelog__body h2 {
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: var(--kanap-text-primary);
  }

  .mk-changelog__body > p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--kanap-text-secondary);
    margin: 0;
  }

  .mk-changelog__section h3 {
    font-size: 12px;
    font-weight: 500;
    color: var(--kanap-text-tertiary);
    margin: 0 0 8px;
    letter-spacing: 0.04em;
  }

  .mk-changelog__section ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mk-changelog__section li {
    position: relative;
    padding-left: 18px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--kanap-text-secondary);
  }

  .mk-changelog__section li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 8px;
    height: 1px;
    background: var(--kanap-text-tertiary);
  }
</style>
