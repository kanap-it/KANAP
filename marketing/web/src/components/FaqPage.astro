---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section, PageHeader, FaqList, CTABand } from './sections';
import { getLocaleFromUrl, localePath } from '../i18n/ui';
import { getFaqContent } from '../content/resolve';

const locale = getLocaleFromUrl(Astro.url);
const c = getFaqContent(locale);

// Inject FAQPage JSON-LD from the first group (structured data likes a flat list)
const ldItems = c.groups.flatMap((g) => g.items);
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: ldItems.map((i) => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a.replace(/<[^>]+>/g, '') },
  })),
};
---

<BaseLayout title={c.meta.title} description={c.meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>

  <PageHeader eyebrow={c.header.eyebrow} title={c.header.title} lead={c.header.lead} />

  <Section tone="default">
    <div class="mk-faq-wrap">
      {c.groups.map((group) => (
        <div class="mk-faq-group">
          <h2 class="mk-faq-group__label">{group.label}</h2>
          <FaqList items={group.items} />
        </div>
      ))}
    </div>
  </Section>

  <Section tone="sunken" compact>
    <CTABand
      title={c.cta.title}
      body={c.cta.body}
      primaryHref={localePath(locale, '/contact')}
      primaryLabel={c.cta.primary}
      secondaryHref={localePath(locale, '/trial/start')}
      secondaryLabel={c.cta.secondary}
    />
  </Section>
</BaseLayout>

<style>
  .mk-faq-wrap {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 820px;
  }

  .mk-faq-group__label {
    font-size: 14px;
    font-weight: 500;
    color: var(--kanap-text-tertiary);
    margin: 0 0 12px;
    letter-spacing: 0.04em;
  }
</style>
