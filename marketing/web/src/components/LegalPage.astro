---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section, PageHeader } from './sections';
import { getLocaleFromUrl, DEFAULT_LOCALE } from '../i18n/ui';
import type { LegalDoc } from '../content/legal/types';

interface Props {
  doc: LegalDoc;
}

const { doc } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const showEnglishNotice = locale !== DEFAULT_LOCALE;
---

<BaseLayout title={doc.meta.title} description={doc.meta.description}>
  <PageHeader eyebrow={doc.header.eyebrow} title={doc.header.title}>
    <Fragment slot="meta">
      <span>{doc.header.lastUpdated}</span>
    </Fragment>
  </PageHeader>

  <Section tone="default">
    {showEnglishNotice && (
      <aside class="mk-legal-lang-notice">
        <p>This document is currently available in English only. A localised translation will follow. The English version is legally binding.</p>
      </aside>
    )}
    <article class="mk-legal" set:html={doc.body} />
  </Section>
</BaseLayout>

<style>
  .mk-legal-lang-notice {
    max-width: 760px;
    padding: 14px 18px;
    background: var(--kanap-bg-drawer);
    border: 1px solid var(--kanap-border-default);
    border-radius: var(--kanap-radius-composer);
    color: var(--kanap-text-secondary);
    font-size: 13px;
    line-height: 1.55;
    margin-bottom: 32px;
  }

  .mk-legal {
    max-width: 760px;
    color: var(--kanap-text-secondary);
    font-size: 15px;
    line-height: 1.7;
  }

  .mk-legal :global(h2) {
    font-size: 18px;
    font-weight: 500;
    color: var(--kanap-text-primary);
    margin: 32px 0 12px;
    line-height: 1.3;
  }

  .mk-legal :global(h2:first-child) {
    margin-top: 0;
  }

  .mk-legal :global(h3) {
    font-size: 15px;
    font-weight: 500;
    color: var(--kanap-text-primary);
    margin: 24px 0 8px;
  }

  .mk-legal :global(p) {
    margin: 0 0 14px;
  }

  .mk-legal :global(ul) {
    margin: 0 0 14px;
    padding-left: 20px;
    list-style: disc;
  }

  .mk-legal :global(ul li) {
    margin-bottom: 6px;
  }

  .mk-legal :global(a) {
    color: var(--kanap-teal);
  }

  .mk-legal :global(a:hover) {
    color: var(--kanap-text-primary);
  }

  .mk-legal :global(strong) {
    color: var(--kanap-text-primary);
    font-weight: 500;
  }

  .mk-legal :global(.mk-legal__foot) {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--kanap-border-soft);
    font-size: 13px;
    color: var(--kanap-text-tertiary);
  }
</style>
