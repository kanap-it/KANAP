# =============================================================================
# KANAP On-Premise Configuration
# Copy this file to ../.env and fill in the values.
# See doc/help/docs/en/on-premise/configuration.md for full reference.
# =============================================================================

# DEPLOYMENT MODE (required)
DEPLOYMENT_MODE=single-tenant

# TENANT CONFIGURATION (optional — defaults shown)
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=My Organization

# ADMIN CREDENTIALS (required)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=ChangeThisPassword123!

# SECURITY (required)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# APPLICATION URL (required — your externally reachable URL)
APP_BASE_URL=https://kanap.your-domain.com

# CORS (required in production — comma-separated origin patterns)
CORS_ORIGINS=https://kanap.your-domain.com

# DATABASE (required — PostgreSQL 16+ with citext, pgcrypto, uuid-ossp extensions;
# use a dedicated application role, never postgres or another cluster-admin role)
DATABASE_URL=postgres://kanap:password@your-postgres:5432/kanap?sslmode=require

# STORAGE (required — S3-compatible object storage)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=kanap-files
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false   # true for MinIO

# EMAIL (optional — Resend; Phase 1 only supports Resend)
# Enables: password reset, user invitations, notification digests
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=KANAP <noreply@yourdomain.com>

# SSO (optional — Microsoft Entra ID)
# See doc/help/docs/en/on-premise/sso-entra.md
# ENTRA_CLIENT_ID=

# ADVANCED (optional — defaults are fine for most deployments)
# LOG_LEVEL=info
# JWT_ACCESS_TOKEN_TTL=15m
# JWT_REFRESH_TOKEN_TTL=4h
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_TRUST_PROXY=false
# INTEGRATED_DOCS_AUTO_ROLLOUT=if-needed
