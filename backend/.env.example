PORT=8080
APP_ENV=development
DATABASE_URL=postgres://app:app@db:5432/appdb
# REQUIRED: set a strong random secret (example: openssl rand -base64 32)
JWT_SECRET=
APP_BASE_URL=http://localhost:5173

# CORS allowed origins (comma-separated). Supports wildcards for SaaS multi-tenancy.
# Patterns:
#   - Exact origin: https://app.kanap.net
#   - Wildcard subdomain: https://*.kanap.net (matches any subdomain)
#   - Wildcard port: http://localhost:* (matches any port)
# Examples by environment:
#   - Local dev: http://localhost:*,http://*.lvh.me:*
#   - Dev/QA: https://*.dev.kanap.net
#   - Production: https://*.kanap.net
#   - On-prem: https://*.customer.internal
# IMPORTANT: This is REQUIRED in production. The app will fail to start if not set.
CORS_ORIGINS=http://localhost:*,http://*.lvh.me:*

# Optional local bootstrap admin (disabled by default)
# When enabling, set a strong unique ADMIN_PASSWORD first.
SEED_ADMIN=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Rate limiting (app-level)
# Enabled by default; set RATE_LIMIT_ENABLED=false to disable.
RATE_LIMIT_ENABLED=true
# Set true when running behind a reverse proxy (Cloudflare/Nginx) that forwards client IPs.
RATE_LIMIT_TRUST_PROXY=false

# CAPTCHA protection (Cloudflare Turnstile)
# Modes:
#   - off: no CAPTCHA verification
#   - monitor: verify when possible, log failures, do not block requests
#   - enforce: require valid CAPTCHA tokens (recommended for production)
CAPTCHA_MODE=off
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Default tenant slug for multitenancy
# Set to your tenant slug (e.g., 'mycompany')
DEFAULT_TENANT_SLUG=default
MARKETING_BASE_URL=https://www.kanap.net
PLATFORM_ADMIN_HOST=platform-admin.kanap.net
# Comma-separated emails granted platform admin rights.
# Falls back to DB role 'administrator' if empty. Supports wildcard '*' (use with caution).
PLATFORM_ADMIN_EMAILS=

# Email (Resend)
# To enable outbound email (password reset, invites, notifications), set the API key.
# Leave blank in local dev to disable sending.
RESEND_API_KEY=
# Optional override for From header
RESEND_FROM_EMAIL="KANAP <no-reply@kanap.net>"

# Notification email links
# Base URL for links in notification emails. The "app" subdomain is replaced with the tenant slug.
# Example: https://app.dev.kanap.net -> https://mytenant.dev.kanap.net
APP_URL=https://app.kanap.net

# Email override (dev/QA only - NEVER use in production)
# When set, ALL outgoing emails are redirected to this address.
# Subject is prefixed with original recipient: "[To: user@example.com] Original Subject"
# EMAIL_OVERRIDE=developer@kanap.net

# Stripe billing (optional — billing is disabled when STRIPE_SECRET_KEY is unset)
# When enabled, STRIPE_WEBHOOK_SECRET and plan price IDs are required.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Plan-specific prices (Small / Standard / Max)
STRIPE_PRICE_SMALL_MONTHLY=
STRIPE_PRICE_SMALL_ANNUAL=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_MAX_ANNUAL=
# Enterprise Support (on-prem, annual only)
STRIPE_PRICE_ENTERPRISE_SUPPORT_ANNUAL=
# Optional override for EU bank-transfer rail country used in send_invoice flows (BE, DE, ES, FR, IE, NL)
STRIPE_EU_BANK_TRANSFER_COUNTRY=FR
# Notification email for enterprise support purchases (optional)
ENTERPRISE_SUPPORT_NOTIFY_EMAIL=
# Legacy (transitional — remove after rollout)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Optional overrides; all three fall back to APP_URL when unset.
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=
# Stripe API version (defaults to 2023-10-16 if unset)
STRIPE_API_VERSION=2025-09-30.clover
# Dev-only: set true to skip webhook signature verification (NEVER in production)
# STRIPE_WEBHOOK_ALLOW_INSECURE=false

# FX rates (optional — works without config using the free tier)
# FX_SPOT_BASE_URL=https://open.er-api.com/v6/latest
# FX_SPOT_API_KEY=

# Entra SSO (optional — all 4 must be set together to enable)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_AUTHORITY=https://login.microsoftonline.com/organizations
ENTRA_REDIRECT_URI=

# Files storage (S3-compatible)
# Default backend: s3. Buckets per env: cio-dev|cio-qa|cio-prod
FILES_STORAGE=s3
S3_BUCKET=cio-dev
S3_REGION=nbg1
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SSE=AES256
