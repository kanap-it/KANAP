{
  "name": "cio-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "mkdir -p dist/email/assets && cp -R src/email/assets/. dist/email/assets/",
    "start": "node dist/main.js",
    "start:migrate": "node ./scripts/migrate-and-start.js",
    "migrate:content:dryrun": "ts-node ./scripts/migrate-content-dryrun.ts",
    "migrate:content:execute": "ts-node ./scripts/migrate-content-execute.ts",
    "migrate:content:verify": "ts-node ./scripts/verify-rich-text-markdown.ts",
    "migrate:content:verify-inline-images": "ts-node ./scripts/verify-inline-base64-images.ts",
    "integrated-docs:backfill": "ts-node ./scripts/backfill-integrated-docs.ts",
    "integrated-docs:verify": "ts-node ./scripts/verify-integrated-docs.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "typeorm": "typeorm-ts-node-commonjs -d src/data-source.ts",
    "test:ai:unit": "ts-node src/common/__tests__/tenant-runner.spec.ts && ts-node src/ai/__tests__/ai-filter.adapter.spec.ts && ts-node src/ai/__tests__/ai-policy.service.spec.ts && ts-node src/ai/__tests__/ai-tool.registry.spec.ts && ts-node src/ai/__tests__/ai-system-prompt.service.spec.ts && ts-node src/ai/__tests__/mcp-api-key-auth.guard.spec.ts && ts-node src/ai/__tests__/ai-api-keys.service.spec.ts && ts-node src/ai/__tests__/ai-chat-orchestrator.service.spec.ts && ts-node src/ai/__tests__/ai-key-management.spec.ts && ts-node src/ai/__tests__/ai-provider-test.service.spec.ts && ts-node src/ai/__tests__/ai-controllers.spec.ts && ts-node src/ai/__tests__/brave-search.service.spec.ts && ts-node src/ai/__tests__/ai-settings.service.spec.ts",
    "test:ai:integration": "ts-node src/ai/__tests__/ai-phase0.integration.spec.ts && ts-node src/ai/__tests__/ai-phase1.integration.spec.ts",
    "test:ai": "npm run test:ai:unit && npm run test:ai:integration",
    "test:tenant-isolation": "ts-node ./scripts/tenant-isolation-audit.ts",
    "test:rls": "ts-node ./scripts/rls-self-test.ts",
    "stripe:migrate": "typeorm-ts-node-commonjs -d src/data-source.ts migration:generate --dr --pretty"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/typeorm": "^10.0.0",
    "adm-zip": "^0.5.12",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dayjs": "^1.11.10",
    "fast-csv": "^4.3.6",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^14.1.2",
    "multer": "^1.4.5-lts.1",
    "nestjs-zod": "^3.0.0",
    "openai": "^6.30.1",
    "pg": "^8.11.3",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.1.0",
    "speakeasy": "^2.0.0",
    "stripe": "^20.3.1",
    "turndown": "^7.2.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.6",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^9.0.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
